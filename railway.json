{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "buildCommand": "mvn clean package -DskipTests -B"
  },
  "deploy": {
    "startCommand": "java -XX:+UseContainerSupport -XX:MaxRAMPercentage=75.0 -jar /app/app.jar",
    "restartPolicyMaxRetries": 3,
    "restartPolicyWindowSeconds": 60,
    "numReplicas": 1,
    "healthcheckPath": "/actuator/health/liveness",
    "healthcheckTimeout": 30,
    "sleepApplication": false
  },
  "variables": {
    "SPRING_DATASOURCE_URL": "jdbc:postgresql://${{Postgres.PGHOST}}:${{Postgres.PGPORT}}/railway",
    "SPRING_DATASOURCE_USERNAME": "${{Postgres.PGUSER}}",
    "SPRING_DATASOURCE_PASSWORD": "${{Postgres.PGPASSWORD}}",
    "SPRING_RABBITMQ_HOST": "${{RabbitMQ.RABBITMQ_HOST}}",
    "SPRING_RABBITMQ_PORT": "${{RabbitMQ.RABBITMQ_PORT}}",
    "SPRING_RABBITMQ_USERNAME": "${{RabbitMQ.RABBITMQ_DEFAULT_USER}}",
    "SPRING_RABBITMQ_PASSWORD": "${{RabbitMQ.RABBITMQ_DEFAULT_PASS}}",
    "APP_RABBIT_EXCHANGE": "rental"
  }
}
